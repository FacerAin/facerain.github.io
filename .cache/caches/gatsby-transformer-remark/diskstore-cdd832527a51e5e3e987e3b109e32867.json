":92,"offset":1155},"end":{"line":23,"column":200,"offset":1263}}},{"type":"text","value":"\nHochreiter & Schmidhuber (1997)에 의해 처음 제안된 모델이다.\n모델 안에 여러 개의 gate를 추가하여 input, output 그리고 memory 간 흐르는 정보를 좀 더 섬세하게 제어하여 Simple RNN의 문제점을 개선하였다. 현재 RNN은 거의 대부분 LSTM을 뜻한다.","position":{"start":{"line":23,"column":200,"offset":1263},"end":{"line":25,"column":122,"offset":1434}}}],"position":{"start":{"line":23,"column":1,"offset":1064},"end":{"line":25,"column":122,"offset":1434}}},{"type":"text","value":"\n"},{"type":"element","tagName":"h4","properties":{"id":"grugated-recurrent-unit","style":"position:relative;"},"children":[{"type":"element","tagName":"a","properties":{"href":"#grugated-recurrent-unit","aria-label":"grugated recurrent unit permalink","class":"anchor before"},"children":[{"type":"raw","value":"<svg aria-hidden=\"true\" focusable=\"false\" height=\"16\" version=\"1.1\" viewBox=\"0 0 16 16\" width=\"16\"><path fill-rule=\"evenodd\" d=\"M4 9h1v1H4c-1.5 0-3-1.69-3-3.5S2.55 3 4 3h4c1.45 0 3 1.69 3 3.5 0 1.41-.91 2.72-2 3.25V8.59c.58-.45 1-1.27 1-2.09C10 5.22 8.98 4 8 4H4c-.98 0-2 1.22-2 2.5S3 9 4 9zm9-3h-1v1h1c1 0 2 1.22 2 2.5S13.98 12 13 12H9c-.98 0-2-1.22-2-2.5 0-.83.42-1.64 1-2.09V6.25c-1.09.53-2 1.84-2 3.25C6 11.31 7.55 13 9 13h4c1.45 0 3-1.69 3-3.5S14.5 6 13 6z\"></path></svg>"}]},{"type":"text","value":"GRU(Gated Recurrent Unit)","position":{"start":{"line":27,"column":6,"offset":1441},"end":{"line":27,"column":31,"offset":1466}}}],"position":{"start":{"line":27,"column":1,"offset":1436},"end":{"line":27,"column":31,"offset":1466}}},{"type":"text","value":"\n"},{"type":"element","tagName":"p","properties":{},"children":[{"type":"text","value":"NYU의 Kyunghyun Cho 교수님의 연구이다. LSTM과 비슷하지만 조금 더 적은 gate로 구현하였다. 그렇기에 성능이 비슷하다면 속도 면에서 LSTM보다 유리하다는 장점을 가지고 있다.","position":{"start":{"line":29,"column":1,"offset":1468},"end":{"line":29,"column":110,"offset":1577}}}],"position":{"start":{"line":29,"column":1,"offset":1468},"end":{"line":29,"column":110,"offset":1577}