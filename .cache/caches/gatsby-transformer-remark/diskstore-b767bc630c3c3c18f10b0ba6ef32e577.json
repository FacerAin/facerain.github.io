fset":389},"end":{"line":13,"column":1,"offset":393},"indent":[1]}},{"type":"text","value":"이것이 반복되니 구글링에 나오지 않는 문제를 해결할 수 있는 힘조차 잃어버린 것 같다. 어떤 문제에 직면하면 해결 방법을 깊이 생각해 보는 것이 아닌 열심히 구글링을 하고있는 나 자신을 발견할 수 있었다.","position":{"start":{"line":13,"column":1,"offset":393},"end":{"line":13,"column":115,"offset":507},"indent":[]}},{"type":"break","position":{"start":{"line":13,"column":115,"offset":507},"end":{"line":14,"column":1,"offset":511},"indent":[1]}},{"type":"text","value":"이런 나 자신을 프로그래머라고 부를 수 있을까? 그저 실력 없는 코더가 되어가는 것 아닐까?","position":{"start":{"line":14,"column":1,"offset":511},"end":{"line":14,"column":52,"offset":562},"indent":[]}}],"position":{"start":{"line":10,"column":1,"offset":230},"end":{"line":14,"column":52,"offset":562},"indent":[1,1,1,1]}},{"type":"paragraph","children":[{"type":"text","value":"오늘부터라도 이런 모습을 조금씩이라도 바꿔나가고 싶다. 그 첫 단계로 논문 읽기를 해보고자 한다.","position":{"start":{"line":16,"column":1,"offset":566},"end":{"line":16,"column":55,"offset":620},"indent":[]}},{"type":"break","position":{"start":{"line":16,"column":55,"offset":620},"end":{"line":17,"column":1,"offset":624},"indent":[1]}},{"type":"text","value":"전문 연구원도 아닌 학부생 개발자가 갑자기 왠 논문 읽기냐고 물어볼 수 있다. 나는 아래와 같은 이유로 논문 읽기 공부를 해보고 싶다.","position":{"start":{"line":17,"column":1,"offset":624},"end":{"line":17,"column":76,"offset":699},"indent":[]}}],"position":{"start":{"line":16,"column":1,"offset":566},"end":{"line":17,"column":76,"offset":699},"indent":[1]}},{"type":"list","ordered":true,"start":1,"spread":false,"children":[{"type":"listItem","spread":false,"checked":null,"children":[{"type":"paragraph","children":[{"type":"strong","children":[{"type":"text","value":"문제해결방법","position":{"start":{"line":19,"column":6,"offset":708},"end":{"line":19,"column":12,"offset":714},"indent":[]}}],"position":{"start":{"line":19,"column":4,"offset":706},"end":{"line":19,"column":14,"offset":716},"indent":[]}},{"type":"break","position":{"start":{"line":19,"column":14,"offset":716},"end":{"line":20,"column":4,"offset":723},"indent":[4]}},{"type":"text","value":"논문이란 결국 “어떤” 문제를 “왜” 그리고 “어떻게” 해결했는지 정리한 문서이다. 여기서 문제의 정의, 조사, 해결, 평가 등을 아우르는 ","position":{"start":{"line":20,"column":4,"offset":723},"end":{"line":20,"column":82,"offset":801},"indent":[]}},{"type":"strong","children":[{"type":"text","value":"문제해결방법","position":{"start":{"line":20,"column":84,"offset":803},"end":{"line":20,"column":90,"offset":809},"indent":[]}}],"position":{"start":{"line":20,"column":82,"offset":801},"end":{"line":20,"column":92,"offset":811},"indent":[]}},{"type":"text","value":"을 논문을 통해 배워보자.","position":{"start":{"line":20,"column":92,"offset":811},"end":{"line":20,"column":106,"offset":825},"indent":[]}}],"position":{"start":{"line":19,"column":4,"offset":706},"end":{"line":20,"column":106,"offset":825},"indent":[4]}}],"position":{"start":{"line":19,"column":1,"offset":703},"end":{"line":20,"column":106,"offset":825},"indent":[1]}},{"type":"listItem","spread":false,"checked":null,"children":[{"type":"paragraph","children":[{"type":"strong","children":[{"type":"text","value":"구현력","position":{"start":{"line":21,"column":6,"offset":832},"end":{"line":21,"column":9,"offset":835},"indent":[]}}],"position":{"start":{"line":21,"column":4,"offset":830},"end":{"line":21,"column":11,"offset":837},"indent":[]}},{"type":"break","position":{"start":{"line":21,"column":11,"offset":837},"end":{"line":22,"column":4,"offset":844},"indent":[4]}},{"type":"text","value":"이번 공부는 읽기에서 끝나는 것이 아니라 논문에 나온 식이나 모델을 직접 코드로 구현해 보고자 한다. 수학문제도 눈으로 푸는 것과 손으로 푸는 것은 확실히 다르다! 개발도 마찬가지다. 논문을 직접 구현해 보면서 읽을 땐 몰랐던 다양한 인사이트와 지식들을 얻어가보자.","position":{"start":{"line":22,"column":4,"offset":844},"end":{"line":22,"column":152,"offset":992},"indent":[]}}],"position":{"start":{"line":21,"column":4,"offset":830},"end":{"line":22,"column":152,"offset":992},"indent":[4]}}],"position":{"start":{"line":21,"column":1,"offset":827},"end":{"line":22,"column":152,"offset":992},"indent":[1]}},{"type":"listItem","spread":false,"checked":null,"children":[{"type":"paragraph","children":[{"type":"strong","children":[{"type":"text","value":"영어","position":{"start":{"line":23,"column":6,"offset":999},"end":{"line":23,"column":8,"offset":1001},"indent":[]}}],"position":{"start":{"line":23,"column":4,"offset":997},"end":{"line":23,"column":10,"offset":1003},"indent":[]}},{"type":"break","position":{"start":{"line":23,"column":10,"offset":1003},"end":{"line":24,"column":4,"offset":1010},"indent":[4]}},{"type":"text","value":"요즘 세상에 영어를 안쓰는 직업이 어디 있을까. 하루가 멀다하고 쏟아져 나오는 최신 기술들을 빠르게 습득할 수 있어야 한다. 물론 이들 자료의 99%는 영어로 작성되어 있다. 언제까지 한글 자료가 나오길 기다릴 순 없다. 논문 읽기를 통해 유창한 영어 실력을 가지는 것은 바라지도 않는다. 대신 영어 문서에 대한 막연한 두려움을 극복해보자.","position":{"start":{"line":24,"column":4,"offset":1010},"end":{"line":24,"column":194,"offset":1200},"indent":[]}}],"position":{"start":{"line":23,"column":4,"offset":997},"end":{"line":24,"column":194,"offset":1200},"indent":[4]}}],"position":{"start":{"line":23,"column":1,"offset":994},"end":{"line":24,"column":194,"offset":1200},"indent":[1]}}],"position":{"start":{"line":19,"column":1,"offset":703},"end":{"line":24,"column":194,"offset":1200},"indent":[1,1,1,1,1]}},{"type":"paragraph","children":[{"type":"text","value":"물론 논문 읽기가 쉬운 공부도 아니고, 여러 난관이 있을 것이다. 하지만 꾸준히 하다보면 무엇이라도 얻는게 있지 않겠나! 한번 열심히 해보자.","position":{"start":{"line":26,"column":1,"offset":1204},"end":{"line":26,"column":80,"offset":1283},"indent":[]}}],"position":{"start":{"line":26,"column":1,"offset":1204},"end":{"line":26,"column":80,"offset":1283},"indent":[]}}],"position":{"start":{"line":1,"column":1,"offset":0},"end":{"line":27,"column":1,"offset":1285}}}}