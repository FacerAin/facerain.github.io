,"column":1,"offset":473},"end":{"line":16,"column":144,"offset":616}}},{"type":"text","value":"\n"},{"type":"element","tagName":"p","properties":{},"children":[{"type":"text","value":"단순히 Matplotlib, Scikit-Learn, Pandas의 사용법을 공부한다고 의미가 있을까? 또한 수학적인 통계, 분석 내용을 다룬다고 써먹을 수 있을까? 그래서 스터디 막바지에 세가지 CS/수학 이론/도메인 지식 역량을 골고루 키울 수 있는 ","position":{"start":{"line":18,"column":1,"offset":618},"end":{"line":18,"column":143,"offset":760}}},{"type":"element","tagName":"strong","properties":{},"children":[{"type":"text","value":"캐글 공부","position":{"start":{"line":18,"column":145,"offset":762},"end":{"line":18,"column":150,"offset":767}}}],"position":{"start":{"line":18,"column":143,"offset":760},"end":{"line":18,"column":152,"offset":769}}},{"type":"text","value":" 로 방향을 정해보았다.","position":{"start":{"line":18,"column":152,"offset":769},"end":{"line":18,"column":165,"offset":782}}}],"position":{"start":{"line":18,"column":1,"offset":618},"end":{"line":18,"column":165,"offset":782}}},{"type":"text","value":"\n"},{"type":"element","tagName":"p","properties":{},"children":[{"type":"text","value":"근데 도저히 한 달동안 진행할 수 있는 분량이 아니었다. 그래서 결국 캐글은 유명한 Titanic 문제만 같이 풀어본채 스터디가 끝나게 되었다. ㅎㅎ;; 한편으로 아쉽기도 하고 좋은 경험이었다고 생각한다. 데이터 사이언스는 하루 아침에 익힐 수 있는 기술이 아닌 것도 느꼈다. 다음 기회가 있다면 캐글 문제를 각자 풀어보고 서로 공유하는 방식으로 진행해보고 싶다.","position":{"start":{"line":20,"column":1,"offset":784},"end":{"line":20,"column":204,"offset":987}}}],"position":{"start":{"line":20,"column":1,"offset":784},"end":{"line":20,"column":204,"offset":987}}}],"position":{"start":{"line":1,"column":1,"offset":0},"end":{"line":22,"column":1,"offset":989}}}}